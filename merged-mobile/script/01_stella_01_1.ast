	block_00050 = {
		{"text"},
		text = {
			ja = {
				{
					"そこそこ大きな肉食獣が、一度探索範囲内にあらわれたが、人間が発する不気味な気配を嫌ってか、すぐ圏外に消えていった。",
				},
			},
			en = {
				{
					"Carnivorous animals are always a possibility, but they mostly avoid humans, leaving as soon as they realize who's making all the noise.",
				},
			},
			cn = {
				{
					"有过还算是巨大的肉食动物出现在了探索范围内，但也许是对人类的气息感到不适，它很快就走远消失了。",
				},
			},
			cn_gt = {
				{
					"先前倒也发现过具备一定体格的食肉动物，但或许是出于对人类气息的厌恶，一进入探测范围，便躲避开了。",
				},
			},
		},
