	block_00023 = {
		{"text"},
		text = {
			ja = {
				{
					"初期予測に基づき、マシンが数キロ離れるまで待機する。",
				},
			},
			en = {
				{
					"Based on the initial readings, the Machine is still several miles off.",
				},
			},
			cn = {
				{
					"按照初步预测，我决定在原地等待机器走出我数公里范围之外。",
				},
			},
			cn_gt = {
				{
