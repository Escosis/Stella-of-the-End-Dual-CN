			},
		},
		linkback = "block_00022",
		linknext = "block_00024",
		line = 156,
	},
	block_00024 = {
		{"text"},
		text = {
			ja = {
				{
					"自ら目と耳を塞いで、通り過ぎるのを待つ。",
