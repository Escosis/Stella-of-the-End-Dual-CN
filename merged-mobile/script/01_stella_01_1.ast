		{"ex", time=500, func="wait"},
		{"text"},
		text = {
			ja = {
				{
					"情報収集の出力と感度を再び上げ、移動を再開する。",
				},
			},
			en = {
				{
					"I turn up my sensors' sensitivity and start moving.",
				},
			},
			cn = {
				{
					"调高信息收集的功率和灵敏度，继续前进。",
				},
			},
			cn_gt = {
				{
					"我将信息收集器的功率与灵敏度重新调高，再次开始移动。",
				},
			},
		},
		linkback = "block_00043",
		linknext = "block_00045",
		line = 254,
	},
	block_00045 = {
		{"text"},
		text = {
			ja = {
				{
					"レーザーを照射したり、電波を飛ばしたりするアクティブな探査は、敵対的な何者かに発見されるリスクを伴うが、膨大な情報ももたらしてくれる。",
				},
			},
			en = {
				{
					"The energy signature of my gear is higher now. I run a bigger risk of giving away my location, but the potential reward is also that much greater.",
				},
			},
			cn = {
				{
					"像这样发射激光或无线电波，采取积极主动的侦查方式有被敌人发现的风险，但也会为我带来海量的信息。",
				},
			},
			cn_gt = {
				{
					"主动探测需要发射激光或电波，存在被敌对势力觉察的风险，但也能收集大量的信息。",
				},
			},
		},
		linkback = "block_00044",
		linknext = "block_00046",
		line = 255,
	},
	block_00046 = {
		{"text"},
		text = {
			ja = {
				{
					"リスクにしても、自身が発するあらゆる電波に欺瞞処理の厚化粧を施せば最小限に抑えられるし、俺にはその技術と知識があった。",
				},
			},
			en = {
				{
					"Fortunately, I have both the tech and knowledge to disguise my vital signs, reducing the risk as much as possible.",
				},
			},
			cn = {
				{
					"而我只需要在自己发出的各种电波上施加厚重的伪装处理，就可以把这种风险降到最低，当然我也具备这方面的技术和知识。",
				},
			},
			cn_gt = {
				{
					"况且，还可以对自身所发出的各类信号进行严密伪装，把风险控制到最小，而我拥有的技术和经验也允许我如此行动。",
				},
			},
		},
		linkback = "block_00045",
		linknext = "block_00047",
		line = 256,
	},
	block_00047 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"危険が去った今は、強気で探索するタイミングだ。",
				},
			},
			en = {
				{
					"Now the immediate danger is passed, I have to make up for the lost time.",
				},
			},
			cn = {
				{
					"现在危险已经远去，正是激进探索的好时机。",
				},
			},
			cn_gt = {
				{
					"如今危险已去，正当积极探索。",
				},
			},
		},
		linkback = "block_00046",
		linknext = "block_00048",
		line = 257,
	},
	block_00048 = {
