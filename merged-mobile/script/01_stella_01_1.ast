		linknext = "block_00025",
		line = 157,
	},
	block_00025 = {
		{"text"},
		text = {
			ja = {
				{
					"今、もし別の敵に襲われたらひとたまりもない。",
				},
			},
			en = {
				{
					"I've left myself open to attack from other threats, I realize that.",
