	block_00056 = {
		{"text"},
		text = {
			ja = {
				{
					"人間に近づけるということは、人間の無能さも再現するということだ。",
				},
			},
			en = {
				{
					"If Philia was made to be as humanlike as possible, perhaps she also has human weaknesses?",
				},
			},
			cn = {
				{
					"接近人类，就意味着也要重现人类的无能。 ",
				},
			},
			cn_gt = {
				{
					"把机器设计得接近人类，也意味着要在机器上实现人类的无能。",
				},
			},
		},
		linkback = "block_00055",
		linknext = "block_00057",
		line = 176,
	},
	block_00057 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"製造者にその意図があったなら、こいつに非人間的な機能は搭載されない。",
				},
			},
			en = {
				{
					"And if that's the case, she probably doesn't have any superhuman abilities, either.",
				},
			},
			cn = {
				{
					"如果制造者有这样的意图，它就不会搭载有非人类的功能。",
				},
			},
			cn_gt = {
				{
					"如果这就是制作厂商的意图，她身上就不会安装非人的功能。",
				},
			},
		},
		linkback = "block_00056",
