			cn = {
				{
					"想做到维持信息收集精度的同时又保证隐秘性，关键就要有适当的选择取舍。",
				},
			},
			cn_gt = {
				{
					"要在保证较高信息收集精度的同时确保自身隐蔽性，关键在于恰当的取舍判断。",
				},
			},
		},
