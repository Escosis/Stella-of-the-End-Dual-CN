	block_00097 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"一度設定してそれっきり一生使えるということはない。常に使い分けが求められる。",
				},
			},
			en = {
				{
					"There's no one-size-fits-all setting. You have to be able to adapt.",
				},
			},
			cn = {
				{
					"没有设置好就一劳永逸的说法，必须时常根据情况调整。",
				},
			},
			cn_gt = {
				{
					"不可能同一个设置用一辈子。经常需要灵活运用。",
				},
			},
		},
		linkback = "block_00096",
		linknext = "block_00098",
		line = 277,
	},
	block_00098 = {
		{"text"},
		text = {
