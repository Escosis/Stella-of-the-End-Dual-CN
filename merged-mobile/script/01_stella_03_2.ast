	block_00206 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z000600290"},
			},
			ja = {
				{
					"「なあ、正直に言え。それは疲労を演出する機能なのか？　それともおまえの認知上に実際生じている許容困難な負荷なのか？」",
				},
			},
			en = {
				{
					[["Are you saying you're too tired to emulate human behavior, or is it a legitimate warning about stress on your system?"]],
				},
			},
			cn = {
				{
					"「我说啊，你老实告诉我，这是什么模拟疲劳的功能吗？　还是说是你实际认知到了难以承受的负载？」",
				},
			},
