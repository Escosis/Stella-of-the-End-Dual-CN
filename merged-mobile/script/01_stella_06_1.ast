				{"vo", ch="c001", file="z001600109"},
			},
			ja = {
				{
					"「文明の末期には、人類は都市レベルで敵対していたからな」",
				},
			},
			en = {
				{
					[["When a society starts to decline, people turn on each other. It's especially bad in big cities."]],
				},
