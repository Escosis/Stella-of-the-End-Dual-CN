			cn = {
				{
					"「在人类社群之外，任何生物都拼命进行着生存竞争。所以外界的人抓到机会就会发动攻击，这就是再正常不过的。",
				},
			},
			cn_gt = {
				{
					"「在群体之外，每个人都拼上性命作生存斗争。因此那些外界的人不会放过任何袭击你的机会。这就是自然法则。",
				},
			},
		},
