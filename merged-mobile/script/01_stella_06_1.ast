		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z001600169"},
			},
			ja = {
				{
					"「こういう場所で遭遇するものは、だいたい各建築物を守る警備機械だ」",
				},
			},
			en = {
				{
					[["We're most likely to run into robots stationed to guard individual buildings."]],
				},
			},
			cn = {
				{
					"「在这种地方能遇到的，通常是保卫各个建筑的安保机器人」",
				},
			},
			cn_gt = {
				{
					"「能在这种地方遇到的，基本上是守卫各处建筑的安保机器」",
				},
			},
		},
		linkback = "block_00132",
		linknext = "block_00134",
		line = 298,
	},
	block_00134 = {
		{"fg", file="bs2_ph01_base01", face="bs2_ph_f01_11", ch="c002", path=":fg/", time=300, mode=3, head="bs2_ph0", lv=3, id=13},
