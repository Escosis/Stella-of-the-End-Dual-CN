				{"vo", ch="c001", file="z001600114"},
			},
			ja = {
				{
					"万民が万民の敵になった時代があったんだ」",
				},
			},
			en = {
				{
					[[That kind of inequality inevitably breeds conflict."]],
				},
			},
			cn = {
				{
					"曾经也有时代，每个人都是彼此的敌人」",
				},
			},
			cn_gt = {
				{
					"曾经还上演过万人大战呢」",
				},
			},
		},
		linkback = "block_00085",
		linknext = "block_00087",
		line = 217,
	},
