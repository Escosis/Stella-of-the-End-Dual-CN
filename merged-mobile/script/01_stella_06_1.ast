		linkback = "block_00077",
		linknext = "block_00079",
		line = 201,
	},
	block_00079 = {
		{"text"},
		text = {
			ja = {
				{
					"すると自動報復攻撃指令を受けた機械群が、そのまま残される。",
				},
			},
			en = {
				{
					"Then, any security robots or anti-personnel machinery would still be in there, complete with their orders to attack rebels on sight.",
				},
