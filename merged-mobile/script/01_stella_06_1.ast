					[["What do we do when we see one?"]],
				},
			},
			cn = {
				{
					"「怎么才能不惹到它们？」",
				},
			},
			cn_gt = {
				{
					"「要注意些什么呢？」",
				},
			},
		},
		linkback = "block_00133",
		linknext = "block_00135",
		line = 300,
	},
	block_00135 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z001600171"},
			},
			ja = {
				{
					"「近寄らないこと。敷地に入らないことだ」",
				},
			},
