	block_00085 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z001600113"},
			},
			ja = {
				{
					"「発掘される遺跡を調べると、同じ時代と地域なのに強烈な技術格差が確認されることが多々あってな。それはこの名残だと言われている。",
				},
			},
			en = {
				{
					[["Sometimes, you find ruins in the same place and from the same era, but there's a huge difference in what technology different people had access to.]],
				},
			},
			cn = {
				{
					"「在调查发掘出的遗址时，即使属于同一时代和地区，也经常能观察到巨大的技术差距。这被认为是这种局面的遗留影响。",
				},
			},
			cn_gt = {
				{
					"「通过调查那些已发掘的遗迹，会发现在很多例子中，即便是在同时代同地区，在技术上也存在着巨大的差异。这也是受其影响吧。",
				},
			},
		},
		linkback = "block_00084",
		linknext = "block_00086",
		line = 216,
	},
	block_00086 = {
		{"text"},
		text = {
