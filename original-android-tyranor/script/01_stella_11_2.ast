				{"vo", ch="c003", file="z004000143"},
			},
			ja = {
				{
					"『君はこの分野の知識には暗いのだな。ＡＩは言語や意味を理解しない。ＡＩの基礎理論は統計・確率・論理だ。万物の解を抽出する三つの神器だよ。",
				},
			},
		},
		linkback = "block_00132",
