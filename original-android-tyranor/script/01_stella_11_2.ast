				{"vo", ch="c001", file="z004000053"},
			},
			ja = {
				{
					"仕事はきっちり果たす。今後は隠し事はなしにしてもらいたい」",
				},
			},
		},
		linkback = "block_00043",
		linknext = "block_00045",
		line = 98,
	},
	block_00045 = {
