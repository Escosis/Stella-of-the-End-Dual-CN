				{"vo", ch="c003", file="z004000141"},
			},
			ja = {
				{
					"『ＡＩは統計的に判断する。成熟した単体のみを排除し、統計上に与える影響を最小限とすることで、閾値を超えないようにしているのだ』",
				},
			},
		},
		linkback = "block_00130",
		linknext = "block_00132",
		line = 270,
	},
	block_00132 = {
