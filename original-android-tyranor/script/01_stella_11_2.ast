		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004000051"},
			},
			ja = {
				{
					"『それは難しいことだ。情報だけを持ち逃げする者もいる。依頼の初期段階では、危険な仕事だと伝えることが限度だ。それを承知の上で受けたのだと思ったが？』",
				},
			},
		},
		linkback = "block_00041",
		linknext = "block_00043",
		line = 96,
	},
	block_00043 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004000052"},
			},
			ja = {
				{
					"「命掛けは承知の上。だとしても、安売りしているわけじゃない。",
				},
			},
		},
		linkback = "block_00042",
		linknext = "block_00044",
		line = 97,
	},
	block_00044 = {
