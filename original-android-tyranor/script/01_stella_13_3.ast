		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004700004"},
			},
			ja = {
				{
					"粘菌のネットワーク実体上に生じる自我を、機械的に複写する手段が存在しない。人間の脳コピーが作れないようにな」",
