		{"bg", file="bg60", x=0, y=-270, speed=30000, ease="none", time=1000, zoom=150, sync=1, path=":bg/", x2=0, y2=270, set="bg60"},
		{"text"},
		text = {
			ja = {
				{
					"男人们会不定期地来到我的身边，进行盘问，向我施加暴力。",
				},
			},
		},
		linkback = "block_00201",
		linknext = "block_00203",
		line = 498,
	},
	block_00203 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"虽然语言不通，但我逐渐搞清楚了这伙人的目的。",
				},
			},
		},
		linkback = "block_00202",
		linknext = "block_00204",
		line = 499,
	},
	block_00204 = {
		{"cgdel", id=-1},
