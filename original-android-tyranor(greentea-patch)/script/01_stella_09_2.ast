		linkback = "block_00206",
		linknext = "block_00208",
		line = 506,
	},
	block_00208 = {
		{"bgm", stop=1, time=2000},
		{"text"},
		text = {
			ja = {
				{
					"想必他们应该经历了一起惨痛的变故，一路逃到了这里。",
