			ja = {
				{
					"时而带着我们的装备过来，寻求说明。",
				},
			},
		},
		linkback = "block_00186",
		linknext = "block_00188",
		line = 465,
	},
	block_00188 = {
		{"text"},
		text = {
			ja = {
				{
					"大部分的盘问中，我都会白挨一顿打。",
				},
			},
		},
		linkback = "block_00187",
		linknext = "block_00189",
		line = 466,
	},
	block_00189 = {
		{"text"},
		text = {
			ja = {
				{
					"开始我还怀疑他们是在享受这种暴力，但现在看来更像是焦躁的表现。",
				},
			},
		},
		linkback = "block_00188",
		linknext = "block_00190",
		line = 467,
	},
	block_00190 = {
		{"text"},
		text = {
			ja = {
				{
					"当初被俘的时候我还没注意到——这些男人都非常憔悴。",
				},
			},
		},
		linkback = "block_00189",
		linknext = "block_00191",
		line = 468,
	},
	block_00191 = {
		{"text"},
		text = {
			ja = {
				{
					"似乎还带着一些伤员。",
				},
			},
		},
		linkback = "block_00190",
		linknext = "block_00192",
		line = 469,
	},
	block_00192 = {
		{"text"},
		text = {
			ja = {
				{
					"这片土地的暑气炙烤着焦躁与恐惧。",
				},
			},
		},
		linkback = "block_00191",
		linknext = "block_00193",
		line = 470,
	},
	block_00193 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"也难怪他们会出现暴力倾向。",
				},
			},
		},
		linkback = "block_00192",
		linknext = "block_00194",
		line = 471,
	},
	block_00194 = {
		{"msgoff"},
		{"cgdel", id=-1},
		{"fg", mode=-2},
		{"bg", file="bg60n", x=0, y=-270, speed=30000, ease="none", time=1000, zoom=150, sync=1, path=":bg/", x2=0, y2=270, set="bg60"},
		{"text"},
		text = {
			ja = {
				{
					"我用视膜屏调查了从采光窗能看到的地方。",
				},
			},
		},
		linkback = "block_00193",
		linknext = "block_00195",
		line = 476,
	},
	block_00195 = {
		{"cgdel", id=-1},
		{"fg", mode=-2},
		{"bg", file="bg36n", x=0, y=270, speed=15000, ease="none", time=1500, zoom=150, sync=0, path=":bg/", x2=0, y2=0, set="bg36"},
		{"text"},
		text = {
			ja = {
				{
					"如果与终端相连，它还能分析许多东西，但单独运作的话，它只具有收发通知、夜视和望远这些基本功能。",
				},
			},
		},
		linkback = "block_00194",
		linknext = "block_00196",
		line = 480,
	},
	block_00196 = {
		{"text"},
		text = {
			ja = {
				{
					"就像一整套计算机设备里只剩显示器的情况一样。",
				},
			},
		},
		linkback = "block_00195",
		linknext = "block_00197",
		line = 481,
	},
	block_00197 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"话是这么说，现在也只能用手头上的东西想想办法。",
				},
			},
		},
		linkback = "block_00196",
		linknext = "block_00198",
		line = 482,
	},
	block_00198 = {
		{"msgoff"},
		{"cgdel", id=-1, sync=0},
		{"fg", mode=-2, sync=0},
		{"bg", file="bg35", x=-480, y=0, speed=35000, ease="none", time=1000, zoom=150, sync=0, path=":bg/", x2=480, y2=0, set="bg35"},
		{"bg", id=1, lv=1, file="cinema200", path=":fgf/", sync=0},
		{"extrans", time=1000},
		{"text"},
		text = {
			ja = {
				{
					"正如菲莉娅所说，他们似乎是占据了废墟，然后将其变成了根据地。",
				},
			},
		},
		linkback = "block_00197",
		linknext = "block_00199",
		line = 488,
	},
	block_00199 = {
		{"text"},
		text = {
			ja = {
				{
					"正门是由木料、废弃材料和轮胎拼凑而成的，极其简易。",
				},
			},
		},
		linkback = "block_00198",
		linknext = "block_00200",
		line = 489,
	},
	block_00200 = {
		{"text"},
		text = {
			ja = {
				{
					"开关依靠人力。",
				},
			},
		},
		linkback = "block_00199",
		linknext = "block_00201",
		line = 490,
	},
	block_00201 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"虽然档次差了些，防些野兽应该没问题。",
				},
			},
		},
		linkback = "block_00200",
		linknext = "block_00202",
		line = 491,
	},
	block_00202 = {
		{"cgdel", id=1, lv=1},
