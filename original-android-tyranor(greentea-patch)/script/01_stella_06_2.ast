		linkback = "block_00006",
		linknext = "block_00008",
		line = 22,
	},
	block_00008 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z001700014"},
			},
			ja = {
				{
					"「根据留存记录，当时各地都市的市民普遍具有要强的自尊心与权利意识，还存在极端的抱怨倾向」",
