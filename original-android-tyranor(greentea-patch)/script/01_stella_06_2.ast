		text = {
			vo = {
				{"vo", ch="c001", file="z001700016"},
			},
			ja = {
				{
					"「不，这就是他们普遍的精神面貌。算是一种民族优越感。想想他们世世代代都生活在这种高科技的城邦里，却也无可厚非」",
