		},
		linkback = "block_00027",
		linknext = "block_00029",
		line = 62,
	},
	block_00029 = {
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_03", ch="c003", path=":fg/", time=300, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003700037"},
			},
			ja = {
				{
					"「我本就会说西部当地的语言，但跟着父亲，也学会了东部的语言」",
				},
			},
		},
		linkback = "block_00028",
		linknext = "block_00030",
		line = 64,
	},
	block_00030 = {
