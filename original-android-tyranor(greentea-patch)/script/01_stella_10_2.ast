		text = {
			vo = {
				{"vo", ch="c004", file="z003700004"},
			},
			ja = {
				{
					"「他们是西边的探险队」",
				},
			},
		},
		linknext = "block_00001",
		line = 12,
	},
	block_00001 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z003700005"},
			},
			ja = {
				{
					"「西边指的是……大陆西部的人类圈吗？」",
				},
			},
		},
		linkback = "block_00000",
		linknext = "block_00002",
		line = 13,
	},
	block_00002 = {
		{"cgdel", id=1, lv=1},
		{"msgoff"},
		{"cgdel", id=-1, sync=0},
		{"fg", mode=-2, sync=0},
		{"bg", file="bg16n", sync=0, path=":bg/", set="bg16"},
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_01", ch="c003", path=":fg/", sync=0, mode=3, head="bs2_de0", lv=3, id=13},
		{"extrans", time=1000},
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_03", ch="c003", path=":fg/", time=300, sync=1, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003700006"},
			},
			ja = {
				{
					"「还不算是大陆西部。",
				},
			},
		},
		linkback = "block_00001",
		linknext = "block_00003",
		line = 19,
	},
	block_00003 = {
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_01", ch="c003", path=":fg/", time=300, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003700007"},
			},
			ja = {
				{
					"他们来自贯穿这个半岛南北的山脉另一侧的土地」",
				},
			},
		},
		linkback = "block_00002",
		linknext = "block_00004",
		line = 21,
	},
	block_00004 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003700008"},
			},
			ja = {
				{
					"「虽说是西边，但离这里也不远啊。那里也有人类圈吗？」",
				},
			},
		},
		linkback = "block_00003",
		linknext = "block_00005",
		line = 22,
	},
	block_00005 = {
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_03", ch="c003", path=":fg/", time=300, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003700009"},
			},
			ja = {
				{
					"「有的。虽然规模比东部要小，不过依然有还算安全的土地和几个小城镇」",
				},
			},
		},
		linkback = "block_00004",
		linknext = "block_00006",
		line = 24,
	},
	block_00006 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003700010"},
			},
			ja = {
				{
					"「从那边过来需要翻越山脉吧。他们为什么来到这里？」",
				},
			},
		},
		linkback = "block_00005",
		linknext = "block_00007",
		line = 25,
	},
	block_00007 = {
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_01", ch="c003", path=":fg/", time=300, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c004", file="z003700011"},
			},
			ja = {
				{
					"「他们是逃到这里的」",
				},
			},
		},
		linkback = "block_00006",
		linknext = "block_00008",
		line = 27,
	},
	block_00008 = {
		{"text"},
		text = {
			ja = {
				{
					"有一次，西边的恶徒们结成团体，企图扩大探索区域。",
				},
			},
		},
		linkback = "block_00007",
		linknext = "block_00009",
		line = 29,
	},
	block_00009 = {
		{"text"},
		text = {
			ja = {
				{
					"但是计划失败了，出现了众多牺牲者。",
				},
			},
		},
		linkback = "block_00008",
		linknext = "block_00010",
		line = 30,
	},
	block_00010 = {
		{"text"},
		text = {
			ja = {
				{
					"其中规模最大的团伙就是那帮家伙，据说曾人数过百。",
				},
			},
		},
		linkback = "block_00009",
		linknext = "block_00011",
		line = 31,
	},
	block_00011 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"探索逐渐深入，当到达半岛底部时，他们犯了一个错误——他们与正在活动的超越机为敌了。",
				},
			},
		},
		linkback = "block_00010",
		linknext = "block_00012",
		line = 32,
	},
	block_00012 = {
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_03", ch="c003", path=":fg/", time=300, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003700018"},
			},
			ja = {
				{
					"「尽管他们持有武器，但在超越机面前什么都不算」",
				},
			},
		},
		linkback = "block_00011",
		linknext = "block_00013",
		line = 35,
	},
	block_00013 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z003700019"},
			},
			ja = {
				{
					"「……我猜也是」",
				},
			},
		},
		linkback = "block_00012",
		linknext = "block_00014",
		line = 36,
	},
	block_00014 = {
		{"fg", mode=-2, time=300},
		{"text"},
		text = {
			ja = {
				{
					"战败后虽然逃走了，但是回乡的路线被机器堵住，迫不得已便逃进了半岛。",
				},
			},
		},
		linkback = "block_00013",
		linknext = "block_00015",
		line = 40,
	},
	block_00015 = {
		{"text"},
		text = {
			ja = {
				{
					"在超越机停止追逐之前，他们一直向南逃窜，结果就被逼到了这里。",
				},
			},
		},
		linkback = "block_00014",
		linknext = "block_00016",
		line = 41,
	},
	block_00016 = {
		{"text"},
		text = {
			ja = {
				{
					"逃亡途中又有人死去，装备也接连弄丢，如今更是陷入了无粮可吃的绝境。",
				},
			},
		},
		linkback = "block_00015",
		linknext = "block_00017",
		line = 42,
	},
	block_00017 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"无论是装备还是粮食，都不足以支撑他们返回西部了。",
				},
			},
		},
		linkback = "block_00016",
		linknext = "block_00018",
		line = 43,
	},
	block_00018 = {
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_03", ch="c003", path=":fg/", time=300, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003700026"},
			},
			ja = {
				{
					"「他们已经开始认真思考是否只能流亡东部了」",
				},
			},
		},
		linkback = "block_00017",
		linknext = "block_00019",
		line = 46,
	},
	block_00019 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003700027"},
			},
			ja = {
				{
					"「那种状态应该是走不到的吧」",
				},
			},
		},
		linkback = "block_00018",
		linknext = "block_00020",
		line = 47,
	},
	block_00020 = {
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_04", ch="c003", path=":fg/", time=300, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003700028"},
			},
			ja = {
				{
					"「是的。但他们已经别无他法了」",
				},
			},
		},
		linkback = "block_00019",
		linknext = "block_00021",
		line = 49,
	},
	block_00021 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z003700029"},
			},
			ja = {
				{
					"「你是何时被他们抓住的？」",
				},
			},
		},
		linkback = "block_00020",
		linknext = "block_00022",
		line = 50,
	},
	block_00022 = {
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_03", ch="c003", path=":fg/", time=300, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003700030"},
			},
			ja = {
				{
					"「我本就是个流浪者。",
				},
			},
		},
		linkback = "block_00021",
		linknext = "block_00023",
		line = 52,
	},
	block_00023 = {
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_01", ch="c003", path=":fg/", time=300, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003700031"},
			},
			ja = {
				{
					"我于西部的某地被制造出来，独自苏醒。",
				},
			},
		},
		linkback = "block_00022",
		linknext = "block_00024",
		line = 54,
	},
	block_00024 = {
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_10", ch="c003", path=":fg/", time=300, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003700032"},
			},
			ja = {
				{
					"回过神来，我已经在荒野上流浪了。我在那时遇到了父亲」",
				},
			},
		},
		linkback = "block_00023",
		linknext = "block_00025",
		line = 56,
	},
	block_00025 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003700033"},
			},
			ja = {
				{
					"「父亲……是那个渡物客吧」",
				},
			},
		},
		linkback = "block_00024",
		linknext = "block_00026",
		line = 57,
	},
	block_00026 = {
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_03", ch="c003", path=":fg/", time=300, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003700034"},
			},
			ja = {
				{
					"「是的。父亲独自一人翻山越岭，从东部来到了这里」",
				},
			},
		},
		linkback = "block_00025",
		linknext = "block_00027",
		line = 59,
	},
	block_00027 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003700035"},
			},
			ja = {
				{
					"「这可真是了不得」",
				},
			},
		},
		linkback = "block_00026",
		linknext = "block_00028",
		line = 60,
	},
	block_00028 = {
		{"fg", file="bs2_de01_base01", face="bs2_de_f01_04", ch="c003", path=":fg/", time=300, mode=3, head="bs2_de0", lv=3, id=13},
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c004", file="z003700036"},
			},
			ja = {
				{
					"「我被父亲收留，随他一同踏上了旅途」",
				},
