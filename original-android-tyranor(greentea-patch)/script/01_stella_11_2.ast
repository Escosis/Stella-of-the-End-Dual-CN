		{"bg", id=2, lv=5, file="ef_monitor_wi09", sync=0, time=300, path=":fgf/"},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004000051"},
			},
			ja = {
				{
					"『此事我也不好妥协，有些人拿完情报便再无下文。在委托初期明言此行危险，已是我最大的让步。你不也是了解情况后才接下委托的吗？』",
				},
			},
		},
		linkback = "block_00041",
		linknext = "block_00043",
		line = 96,
	},
	block_00043 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004000052"},
			},
			ja = {
				{
					"「我知道这活是要玩命的，但这不代表我会贱卖自己。",
				},
			},
		},
		linkback = "block_00042",
		linknext = "block_00044",
		line = 97,
	},
	block_00044 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004000053"},
			},
			ja = {
				{
					"我保证如实完成工作，希望你今后别再对我藏着掖着」",
				},
			},
		},
		linkback = "block_00043",
		linknext = "block_00045",
		line = 98,
	},
	block_00045 = {
