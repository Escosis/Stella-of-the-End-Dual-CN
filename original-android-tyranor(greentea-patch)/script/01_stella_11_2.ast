			ja = {
				{
					"『经过一路磨合，仿生人应当具备相对丰富的经验，与渡物客构筑一定信赖关系，哪怕只是草草应付也当有此程度。而负责黛莉拉的渡物客，连这都没能做到』",
				},
			},
		},
		linkback = "block_00080",
		linknext = "block_00082",
		line = 157,
	},
	block_00082 = {
		{"msgoff"},
		{"cgdel", id=1, lv=5},
		{"cgdel", id=2, lv=5},
		{"cgdel", id=20, lv=9},
		{"fg", mode=-2},
		{"bg", file="cg_ts50", speed=35000, time=1000, zoom=100, lv=5, z2=150, sync=1, ease="none", path=":ev/", id=1, set="ts50"},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004000093"},
			},
			ja = {
				{
					"『他只当黛莉拉是件货物、是台机器般拖了过来。验收时，还证实他在枪战中将黛莉拉当做掩体使用。他的行为实属恶劣，我因而削减了他的报酬』",
				},
			},
		},
		linkback = "block_00081",
		linknext = "block_00083",
		line = 163,
	},
	block_00083 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004000094"},
			},
			ja = {
				{
					"「真的是这样……？」",
				},
			},
		},
		linkback = "block_00082",
		linknext = "block_00084",
		line = 164,
	},
	block_00084 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004000095"},
			},
			ja = {
				{
					"『我又何必虚言？具备职业精神的渡物客凤毛麟角，这一点你应比我更清楚』",
				},
			},
		},
		linkback = "block_00083",
		linknext = "block_00085",
		line = 165,
	},
	block_00085 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z004000096"},
			},
			ja = {
				{
					"「我倒不是怀疑这个，只是这和黛莉拉说的出入太大……」",
				},
			},
		},
		linkback = "block_00084",
		linknext = "block_00086",
		line = 166,
	},
	block_00086 = {
		{"text"},
		text = {
			ja = {
				{
					"父亲。",
				},
			},
		},
		linkback = "block_00085",
		linknext = "block_00087",
		line = 168,
	},
	block_00087 = {
		{"text"},
		text = {
			ja = {
				{
					"教了她很多东西。",
				},
			},
		},
		linkback = "block_00086",
		linknext = "block_00088",
		line = 169,
	},
	block_00088 = {
		{"text"},
		text = {
			ja = {
				{
					"科学的信奉者。",
				},
			},
		},
		linkback = "block_00087",
		linknext = "block_00089",
		line = 170,
	},
	block_00089 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"我根据这些话想象出的高洁形象就此坍塌。",
				},
			},
		},
		linkback = "block_00088",
		linknext = "block_00090",
		line = 171,
	},
	block_00090 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004000103"},
			},
			ja = {
				{
					"『我不知道黛莉拉是如何说的，但真相如此。他不接受我对报酬的削减，谈判因而破裂，他便带着黛莉拉离开了』",
				},
			},
		},
		linkback = "block_00089",
		linknext = "block_00091",
		line = 173,
	},
	block_00091 = {
