				{"vo", ch="c003", file="z004000063"},
			},
			ja = {
				{
					"『那只是一般情况，且是针对古代ＡＩ而言。如今的ＡＩ对人类心理的认知有多清晰，还完全是个未知数』",
				},
			},
		},
		linkback = "block_00053",
		linknext = "block_00055",
