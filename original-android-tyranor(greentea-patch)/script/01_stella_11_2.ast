				{"vo", ch="c003", file="z004000143"},
			},
			ja = {
				{
					"『看来你对此领域所知甚少。ＡＩ并不会去理解语言和意义。ＡＩ的基础理论是统计、概率、逻辑，此为提取万物通解的三大神器。",
				},
			},
		},
		linkback = "block_00132",
		linknext = "block_00134",
		line = 273,
	},
	block_00134 = {
