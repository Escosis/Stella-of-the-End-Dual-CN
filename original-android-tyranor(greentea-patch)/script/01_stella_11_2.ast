				{"vo", ch="c001", file="z004000104"},
			},
			ja = {
				{
					"「……」",
				},
			},
		},
		linkback = "block_00090",
		linknext = "block_00092",
		line = 174,
	},
	block_00092 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004000105"},
			},
			ja = {
				{
					"『他或许是试图激我主动提出重新交涉，然而我并无此意。此人品性实属低劣。",
				},
			},
		},
		linkback = "block_00091",
		linknext = "block_00093",
