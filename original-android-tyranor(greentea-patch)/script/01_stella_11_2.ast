		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004000141"},
			},
			ja = {
				{
					"『ＡＩ的判断基于统计结果。只清除成熟的单一个体，将统计层面的影响抑制到最低，以此将判定数值限制在阈值之下』",
				},
			},
		},
