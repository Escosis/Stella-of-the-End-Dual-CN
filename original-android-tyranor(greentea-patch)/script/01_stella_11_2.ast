				{"vo", ch="c003", file="z004000061"},
			},
			ja = {
				{
					"『如今ＡＩ掌控了大部分通信网络，通过这些渠道传输的信息是可能随时受它们监听的』",
				},
			},
		},
		linkback = "block_00051",
		linknext = "block_00053",
