			vo = {
				{"vo", ch="c001", file="z004000062"},
			},
			ja = {
				{
					"「……就算窃听到了，它们也未必能理解内容吧。你不是说哪怕ＡＩ进行了统计，也没法对其中的信息进行解释吗？」",
				},
			},
