	},
	block_00208 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003100259"},
			},
			ja = {
				{
					"「估计是因为它们并不是为了争个输赢吧。在人类眼里，这是斗争，但在ＡＩ的认识中，这只是清除障碍而已，不是吗？」",
				},
			},
		},
		linkback = "block_00207",
		linknext = "block_00209",
		line = 529,
	},
