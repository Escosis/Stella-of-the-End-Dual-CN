		linknext = "block_00207",
		line = 527,
	},
	block_00207 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z003100258"},
			},
			ja = {
				{
					"有趣的是，不同于人类间的争斗，即便直接攻击对方的本体、消灭对方便能取得胜利，它们却并没有如此选择』",
				},
			},
