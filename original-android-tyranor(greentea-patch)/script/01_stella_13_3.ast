		},
		linkback = "block_00010",
		linknext = "block_00012",
		line = 34,
	},
	block_00012 = {
		{"fg", file="bs3_wi01_base01", face="bs3_wi_f01_01", ch="c005", path=":fg/", time=300, mode=3, head="bs3_wi0", lv=3, id=13},
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c003", file="z004700018"},
			},
			ja = {
				{
					"「你若希望，那也可留在此处亲自负责研究。终有一日，你能够开发出复制Ａｅ型仿生人自我的技术」",
