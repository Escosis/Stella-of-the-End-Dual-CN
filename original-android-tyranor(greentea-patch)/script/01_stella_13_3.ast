			},
		},
		linkback = "block_00005",
		linknext = "block_00007",
		line = 26,
	},
	block_00007 = {
		{"text"},
		text = {
			ja = {
				{
					"也许，我面前这位老人的心里也对自己的所作所为有罪恶感。",
