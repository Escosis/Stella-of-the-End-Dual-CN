		linkback = "block_00011",
		linknext = "block_00013",
		line = 37,
	},
	block_00013 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"复制的结果也不过是菲莉娅变成了两个，解决不了问题。",
