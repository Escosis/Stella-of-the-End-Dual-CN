		text = {
			vo = {
				{"vo", ch="c001", file="z003800208"},
			},
			ja = {
				{
					"「没有其他理由了。应该就是这样的」",
				},
			},
		},
		linkback = "block_00163",
		linknext = "block_00165",
		line = 398,
	},
	block_00165 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c004", file="z003800209"},
			},
			ja = {
				{
					"「太好了……我不懂父亲的梦想……所以我想，哪怕我们分开，只要能帮到父亲就好」",
				},
			},
		},
		linkback = "block_00164",
		linknext = "block_00166",
		line = 399,
	},
	block_00166 = {
		{"text"},
		text = {
			ja = {
				{
					"黛莉拉的声音渐渐变得像是梦中呓语一般。",
				},
			},
		},
		linkback = "block_00165",
		linknext = "block_00167",
		line = 401,
	},
	block_00167 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"她的眼睛早已失去了焦点。",
				},
			},
