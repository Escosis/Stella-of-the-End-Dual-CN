		linknext = "block_00170",
		line = 405,
	},
	block_00170 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003800216"},
			},
			ja = {
				{
					"「而你的父亲，最后确实选择了跟你在一起吧。",
