		linkback = "block_00169",
		linknext = "block_00171",
		line = 406,
	},
	block_00171 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003800217"},
			},
			ja = {
				{
					"我想，你父亲最后大概放弃了自己的梦想。你明白这意味着什么吗？」",
