				{"vo", ch="c001", file="z003800183"},
			},
			ja = {
				{
					"「但说无妨」",
				},
			},
		},
		linkback = "block_00142",
		linknext = "block_00144",
		line = 371,
	},
	block_00144 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003800184"},
			},
			ja = {
				{
					"「其实我和父亲，曾经去过格劳纳公爵那里」",
				},
			},
		},
		linkback = "block_00143",
		linknext = "block_00145",
		line = 372,
	},
	block_00145 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003800185"},
			},
			ja = {
				{
					"「……你说什么？」",
				},
			},
		},
		linkback = "block_00144",
		linknext = "block_00146",
		line = 373,
	},
	block_00146 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003800186"},
			},
			ja = {
				{
					"「但是我们之后又回到了半岛。",
				},
			},
		},
		linkback = "block_00145",
		linknext = "block_00147",
		line = 374,
	},
	block_00147 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003800187"},
			},
			ja = {
				{
					"我就在那时被那些男人们囚禁了。之前因为无法完全信任你们二位，所以就没有阐明原委」",
				},
			},
		},
		linkback = "block_00146",
		linknext = "block_00148",
		line = 375,
	},
	block_00148 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c002", file="z003800188"},
			},
			ja = {
				{
					"「你们去过老公爵那里了吗？」",
				},
			},
		},
		linkback = "block_00147",
		linknext = "block_00149",
		line = 376,
	},
	block_00149 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003800189"},
			},
			ja = {
				{
					"「应该是去过的，但是我已经没有那时的记忆了",
				},
			},
		},
		linkback = "block_00148",
		linknext = "block_00150",
		line = 377,
	},
	block_00150 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c004", file="z003800190"},
			},
			ja = {
				{
					"枪战的时候我的头被打到，那个时候记忆也连带消失了」",
				},
			},
		},
		linkback = "block_00149",
		linknext = "block_00151",
		line = 378,
	},
	block_00151 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"黛莉拉颤抖着用右手指向自己破损的头部。",
				},
			},
		},
		linkback = "block_00150",
		linknext = "block_00152",
		line = 380,
	},
	block_00152 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003800194"},
			},
			ja = {
				{
					"「是见到公爵了，还是没见到呢……我们又为什么要返回呢，我已经不记得这些细节了……」",
				},
			},
		},
		linkback = "block_00151",
		linknext = "block_00153",
		line = 382,
	},
	block_00153 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c002", file="z003800195"},
			},
			ja = {
				{
					"「这样啊」",
				},
			},
		},
		linkback = "block_00152",
		linknext = "block_00154",
		line = 383,
	},
	block_00154 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c004", file="z003800196"},
			},
			ja = {
				{
					"「所以，我无法给二位提供有用的信息」",
				},
			},
		},
		linkback = "block_00153",
		linknext = "block_00155",
		line = 384,
	},
	block_00155 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003800197"},
			},
			ja = {
				{
					"「其中缘由我大概能理解。虽说只是想象」",
				},
			},
		},
		linkback = "block_00154",
		linknext = "block_00156",
		line = 385,
	},
	block_00156 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c004", file="z003800198"},
			},
			ja = {
				{
					"「啊，真的吗？」",
				},
			},
		},
		linkback = "block_00155",
		linknext = "block_00157",
		line = 386,
	},
	block_00157 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003800199"},
			},
			ja = {
				{
					"「大概是意见不合吧。你父亲的梦想和公爵的梦想并不一致。",
				},
			},
		},
		linkback = "block_00156",
		linknext = "block_00158",
		line = 387,
	},
	block_00158 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003800200"},
			},
			ja = {
				{
					"他是个追逐梦想的人，那么他的理想应该也很远大吧？",
				},
			},
		},
		linkback = "block_00157",
		linknext = "block_00159",
		line = 388,
	},
	block_00159 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003800201"},
			},
			ja = {
				{
					"所以大概他就觉得，不能把黛莉拉托付于公爵的梦想吧。",
				},
			},
		},
		linkback = "block_00158",
		linknext = "block_00160",
		line = 389,
	},
	block_00160 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z003800202"},
			},
			ja = {
				{
					"说不准他把你当作他的好女儿了呢」",
				},
			},
		},
		linkback = "block_00159",
		linknext = "block_00161",
		line = 390,
	},
	block_00161 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c004", file="z003800203"},
			},
			ja = {
				{
					"「啊——」",
				},
			},
		},
		linkback = "block_00160",
		linknext = "block_00162",
		line = 391,
	},
	block_00162 = {
