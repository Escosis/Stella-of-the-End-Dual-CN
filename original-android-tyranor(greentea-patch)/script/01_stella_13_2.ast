		{"fg", file="bs3_ph02_base01", face="bs3_ph_f01_10", ch="c002", path=":fg/", time=300, mode=3, head="bs3_ph0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c002", file="z004600263"},
			},
			ja = {
				{
					"「你想让我做什么？」",
				},
			},
		},
		linkback = "block_00218",
		linknext = "block_00220",
		line = 659,
	},
	block_00220 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600264"},
			},
			ja = {
				{
					"「哦……？",
				},
			},
		},
		linkback = "block_00219",
		linknext = "block_00221",
		line = 660,
	},
	block_00221 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600265"},
			},
			ja = {
				{
					"你已预见到了后续发展么。明知如此，却并不试图逃脱，仍留在此处。",
				},
			},
		},
		linkback = "block_00220",
		linknext = "block_00222",
		line = 661,
	},
	block_00222 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c003", file="z004600266"},
			},
			ja = {
				{
					"好，好啊……你是最优秀的Ａｅ型」",
				},
			},
		},
		linkback = "block_00221",
		linknext = "block_00223",
		line = 662,
	},
	block_00223 = {
		{"fg", file="bs3_ph02_base01", face="bs3_ph_f01_13", ch="c002", path=":fg/", time=300, mode=3, head="bs3_ph0", lv=3, id=13},
		{"text"},
		text = {
