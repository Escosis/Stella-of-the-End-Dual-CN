		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z900000021"},
			},
			ja = {
				{
					"话虽如此，性能还是相当卓越的。尽管多少有些愚笨，略做解释后倒也可堪差遣，应用价值相较普通机器人有天壤之别」",
				},
			},
		},
		linkback = "block_00094",
