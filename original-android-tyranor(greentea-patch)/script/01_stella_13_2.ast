		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600125"},
			},
			ja = {
				{
					"「尚在初生期时会活跃地增殖扩张，随着年限的增加，活动性便会渐次降低」",
				},
			},
		},
		linkback = "block_00096",
		linknext = "block_00098",
