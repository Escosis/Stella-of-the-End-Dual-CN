		text = {
			vo = {
				{"vo", ch="c001", file="z004600134"},
			},
			ja = {
				{
					"「信息交叉学？」",
				},
			},
		},
		linkback = "block_00105",
		linknext = "block_00107",
		line = 358,
	},
	block_00107 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_02", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600135"},
			},
			ja = {
				{
					"「在多个领域有所建树者便被如此称呼。主要工作为游走于各个专业领域之间，进行不受视野所限的纵向研究。",
				},
			},
		},
		linkback = "block_00106",
		linknext = "block_00108",
		line = 360,
	},
	block_00108 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_01", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600136"},
			},
			ja = {
				{
					"同为交叉学者，所知也未必相同。一切全看专业的搭配，有时交叉学者间也完全无法交流。",
				},
			},
		},
		linkback = "block_00107",
		linknext = "block_00109",
		line = 362,
	},
	block_00109 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_02", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600137"},
			},
			ja = {
				{
					"我所选择的是遗传学、信息工程，以及临床医学。不过那都是初出茅庐时的事了，如今我已在更广阔的领域钻研」",
				},
			},
		},
		linkback = "block_00108",
		linknext = "block_00110",
		line = 364,
	},
	block_00110 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004600138"},
			},
			ja = {
				{
					"「遗传学，这还挺意外的」",
				},
			},
		},
		linkback = "block_00109",
		linknext = "block_00111",
		line = 365,
	},
	block_00111 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_04", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600139"},
			},
			ja = {
				{
					"「或许吧。然而若无此领域的知识，我便无法察觉……」",
				},
			},
		},
		linkback = "block_00110",
		linknext = "block_00112",
		line = 367,
	},
	block_00112 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z004600140"},
			},
			ja = {
				{
					"「察觉？」",
				},
			},
		},
		linkback = "block_00111",
		linknext = "block_00113",
		line = 368,
	},
	block_00113 = {
		{"msgoff"},
		{"fg", mode=-2, sync=0},
		{"bg", file="b_bg25", sync=0, zoom=150, path=":bg2/", set="bg25"},
		{"fg", file="bs3_wi01_base01", face="bs3_wi_f01_08", ch="c005", path=":fg/", sync=0, mode=3, head="bs3_wi0", lv=3, id=13},
		{"extrans", time=1000},
		{"bgm", stop=1},
		{"fg", file="bs3_wi01_base01", face="bs3_wi_f01_10", ch="c005", path=":fg/", time=300, sync=1, mode=3, head="bs3_wi0", lv=3, id=13},
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c003", file="z004600141"},
			},
			ja = {
				{
					"「如今管理着地球的ＡＩ群，并没有将当今人类认定为人类这一事实」",
				},
			},
		},
		linkback = "block_00112",
		linknext = "block_00114",
		line = 376,
	},
	block_00114 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"我的反应慢了一拍。",
				},
			},
		},
		linkback = "block_00113",
		linknext = "block_00115",
		line = 378,
	},
	block_00115 = {
		{"msgoff"},
		{"fg", mode=-2, sync=0},
		{"bg", file="b_bg25", sync=0, zoom=125, path=":bg2/", set="bg25"},
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_10", ch="c005", path=":fg/", sync=0, mode=3, head="bs2_wi0", lv=3, id=13},
		{"extrans", time=1000},
		{"bgm", file="bgm09"},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004600145"},
			},
			ja = {
				{
					"「……我不太理解你的意思。你是说……人类，不是人类？」",
				},
			},
		},
		linkback = "block_00114",
		linknext = "block_00116",
		line = 384,
	},
	block_00116 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_08", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600146"},
			},
			ja = {
				{
					"「如今的人类在基因层面上已不是人类」",
				},
			},
		},
		linkback = "block_00115",
		linknext = "block_00117",
		line = 386,
	},
	block_00117 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z004600147"},
			},
			ja = {
				{
					"「为什么会这样？」",
				},
			},
		},
		linkback = "block_00116",
		linknext = "block_00118",
		line = 387,
	},
	block_00118 = {
		{"fg", mode=-2, time=300},
		{"msgoff"},
		{"bg", id=2, lv=5, file="ef_ui28_01", zoom=125, y=100, speed=12000, ease="in", style="ar_screen", path=":cg2/", y2=-100, sync=0},
		{"bg", id=1, lv=5, file="ef_ui28_02", zoom=150, y=50, speed=12000, ease="in", path=":cg2/", y2=-50, sync=0},
		{"extrans", time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600148"},
			},
			ja = {
				{
					"「人类的基因本就时刻进行着变异。当今人类比之一万年前的人类，外形虽无变化，基因层面却有所不同。",
				},
			},
		},
		linkback = "block_00117",
		linknext = "block_00119",
		line = 394,
	},
	block_00119 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c003", file="z004600149"},
			},
			ja = {
				{
					"比如体温，比起一万年前的人类，当今人类的平均体温有所下降，据说这是由于在室内居住所导致的变化」",
				},
			},
		},
		linkback = "block_00118",
		linknext = "block_00120",
		line = 395,
	},
	block_00120 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004600150"},
			},
			ja = {
				{
					"「可我们毫无疑问是人，又不是长了四条胳膊」",
				},
			},
		},
		linkback = "block_00119",
		linknext = "block_00121",
		line = 414,
	},
	block_00121 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600151"},
			},
			ja = {
				{
					"「即便差别甚微，在ＡＩ眼中便是决定性的差异。",
				},
			},
		},
		linkback = "block_00120",
		linknext = "block_00122",
		line = 415,
	},
	block_00122 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c003", file="z004600152"},
			},
			ja = {
				{
					"在ＡＩ初步投入使用时，这根本算不上问题。然而随着时间的流逝，我们人类却脱离了定义」",
				},
			},
		},
		linkback = "block_00121",
		linknext = "block_00123",
		line = 416,
	},
	block_00123 = {
		{"msgoff"},
		{"cgdel", id=-1},
		{"fg", mode=-2, sync=0},
		{"bg", file="b_bg25", sync=0, zoom=125, path=":bg2/", set="bg25"},
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_09", ch="c005", path=":fg/", sync=0, mode=3, head="bs2_wi0", lv=3, id=13},
		{"extrans", time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004600153"},
			},
			ja = {
				{
					"「ＡＩ不把我们当人类看么……」",
				},
			},
		},
		linkback = "block_00122",
		linknext = "block_00124",
		line = 422,
	},
	block_00124 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_11", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
