				{"vo", ch="c002", file="z004600267"},
			},
			ja = {
				{
					"「你是想让我控制ＡＩ？」",
				},
			},
		},
		linkback = "block_00222",
		linknext = "block_00224",
		line = 664,
	},
	block_00224 = {
