				{"vo", ch="c003", file="z004600154"},
			},
			ja = {
				{
					"「它们只当我们是其他生物。",
				},
			},
		},
		linkback = "block_00123",
		linknext = "block_00125",
		line = 424,
	},
	block_00125 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_10", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c003", file="z004600155"},
			},
			ja = {
				{
					"因此，它们不再对我们进行任何援助」",
				},
			},
