				{"vo", ch="c001", file="z004600124"},
			},
			ja = {
				{
					"「原来黏菌会在一定时间后固定么」",
				},
			},
		},
		linkback = "block_00095",
		linknext = "block_00097",
		line = 342,
	},
	block_00097 = {
