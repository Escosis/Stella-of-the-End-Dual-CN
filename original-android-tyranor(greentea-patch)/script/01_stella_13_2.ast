			vo = {
				{"vo", ch="c003", file="z004600132"},
			},
			ja = {
				{
					"「如此反应在所难免。这些时间里，我的大脑并未停止活动，也可称之奇迹了」",
				},
			},
		},
		linkback = "block_00103",
		linknext = "block_00105",
