		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600231"},
			},
			ja = {
				{
					"不过也可简单推测，ＡＩ群中存在少数个体，认为可将现存人类纳入人类定义中。当然，实际的运行逻辑要复杂得多」",
				},
			},
		},
		linkback = "block_00186",
		linknext = "block_00188",
		line = 594,
	},
	block_00188 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004600232"},
			},
			ja = {
				{
					"「你的意思是，出于少数派意见的Ａｅ计划能得以实行，完全是特例？」",
				},
			},
		},
		linkback = "block_00187",
		linknext = "block_00189",
		line = 595,
	},
	block_00189 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_06", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c003", file="z004600233"},
			},
			ja = {
				{
					"「没错。生产Ａｅ型几乎不需要耗费能源与资源，直接回收利用地面上残存的设备与物资即可」",
				},
			},
		},
		linkback = "block_00188",
		linknext = "block_00190",
		line = 597,
	},
	block_00190 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004600234"},
			},
			ja = {
				{
					"「就是低风险的试错手段么」",
				},
			},
		},
		linkback = "block_00189",
		linknext = "block_00191",
		line = 598,
	},
	block_00191 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_08", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600235"},
			},
			ja = {
				{
					"「高加索群拥有可观的能源、资源储备，财大气粗，想必它们对新计划的通过标准会放得相对宽松」",
				},
			},
		},
		linkback = "block_00190",
		linknext = "block_00192",
		line = 600,
	},
	block_00192 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004600236"},
			},
			ja = {
				{
					"「你对ＡＩ阵营内部了解得还真清楚」",
				},
			},
		},
		linkback = "block_00191",
		linknext = "block_00193",
		line = 601,
	},
	block_00193 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_04", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600237"},
			},
			ja = {
				{
					"「我长年监测ＡＩ群的活动，分析它们对所获能源的分配、设备运作情况等数据，同时积极收集古代电子信息。",
				},
			},
		},
		linkback = "block_00192",
		linknext = "block_00194",
		line = 603,
	},
	block_00194 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_02", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600238"},
			},
			ja = {
				{
					"毕竟若能得到它们的援手，万事皆有可能」",
				},
			},
		},
		linkback = "block_00193",
		linknext = "block_00195",
		line = 605,
	},
	block_00195 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004600239"},
			},
			ja = {
				{
					"「所以你被猩红之眼盯上，就是因为这个？」",
				},
			},
		},
		linkback = "block_00194",
		linknext = "block_00196",
		line = 606,
	},
	block_00196 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_08", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c003", file="z004600240"},
			},
			ja = {
				{
					"「是。我的活动也同样受ＡＩ监测。通过相关信息对目标进行分析，这正是ＡＩ所擅长的领域。这是被对方以彼之道还治彼身了」",
				},
			},
		},
		linkback = "block_00195",
		linknext = "block_00197",
		line = 608,
	},
	block_00197 = {
		{"text"},
		text = {
			ja = {
				{
					"老爷子也是没想到，猩红之眼所属的亚欧群竟然会对高加索群的Ａｅ计划加以最高度的警戒。",
				},
			},
		},
		linkback = "block_00196",
		linknext = "block_00198",
		line = 610,
	},
	block_00198 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"不难想象，有人监测ＡＩ的活动，还试图打探Ａｅ计划的情况，猩红之眼自然会将其视作敌对势力。",
				},
			},
		},
		linkback = "block_00197",
		linknext = "block_00199",
		line = 611,
	},
	block_00199 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_06", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600241"},
			},
			ja = {
				{
					"「结果，它们认为我的活动是攻击性、侵略性的」",
				},
			},
		},
		linkback = "block_00198",
		linknext = "block_00200",
		line = 614,
	},
	block_00200 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004600242"},
			},
			ja = {
				{
					"「它们是在统计层面认定你具有危险」",
				},
			},
		},
		linkback = "block_00199",
		linknext = "block_00201",
		line = 615,
	},
	block_00201 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_04", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600243"},
			},
			ja = {
				{
					"「总体而言便是如此」",
				},
			},
		},
		linkback = "block_00200",
		linknext = "block_00202",
		line = 617,
	},
	block_00202 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004600244"},
			},
			ja = {
				{
					"「原来是这样……如果有人能掌握一台成熟的Ａｅ型，便能任意操控ＡＩ的援助。这事放在人类之间，已经足够让人动暗杀的心思了。",
				},
			},
		},
		linkback = "block_00201",
		linknext = "block_00203",
		line = 618,
	},
	block_00203 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z004600245"},
			},
			ja = {
				{
					"这和你刚才说的，ＡＩ会耿直地遵从初始指令好像有些矛盾吧」",
				},
			},
		},
		linkback = "block_00202",
		linknext = "block_00204",
		line = 619,
	},
	block_00204 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_06", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600246"},
			},
			ja = {
				{
					"「ＡＩ不长于推理，此乃事实，可这并不意味着它们毫无警惕。群体化ＡＩ的变通能力是超越人智的。",
				},
			},
		},
		linkback = "block_00203",
		linknext = "block_00205",
		line = 621,
	},
	block_00205 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_05", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600247"},
			},
			ja = {
				{
					"试错能够填补ＡＩ推理能力不足的缺陷。如同人类用对方的生日、纪念日来猜测密码一样，ＡＩ能通过",
					{"txruby", text="ブルートフォース"},
					"暴力遍历",
					{"txruby"},
					"得出同样的结果。",
				},
			},
		},
		linkback = "block_00204",
		linknext = "block_00206",
		line = 623,
	},
	block_00206 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_08", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600248"},
			},
			ja = {
				{
					"Ａｅ型能够拥有自我，也是通过这种方式得出的方案。",
				},
			},
		},
		linkback = "block_00205",
		linknext = "block_00207",
		line = 625,
	},
	block_00207 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_11", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600249"},
			},
			ja = {
				{
					"早期型号的性能较为低下。你且想想有名的恐怖谷效应，而那个时期的人类又对机器抱有很大的偏见。",
				},
			},
		},
		linkback = "block_00206",
		linknext = "block_00208",
		line = 627,
	},
	block_00208 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_10", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c003", file="z004600250"},
			},
			ja = {
				{
					"因此，想必当时有数以百……不，万计的Ａｅ型遭到破坏」",
				},
			},
		},
		linkback = "block_00207",
		linknext = "block_00209",
		line = 629,
	},
	block_00209 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"菲莉娅靠向了我。",
				},
			},
		},
		linkback = "block_00208",
		linknext = "block_00210",
		line = 631,
	},
	block_00210 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_08", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600254"},
			},
			ja = {
				{
					"「如此，经过选择淘汰后，ＡＩ便会制造出更适应环境的仿生人。",
				},
			},
		},
		linkback = "block_00209",
		linknext = "block_00211",
		line = 634,
	},
	block_00211 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_10", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600255"},
			},
			ja = {
				{
					"之后便是循环，破坏、生成、破坏、生成」",
				},
			},
		},
		linkback = "block_00210",
		linknext = "block_00212",
		line = 636,
	},
	block_00212 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004600256"},
			},
			ja = {
				{
					"「其中就没有成功的个体吗？」",
				},
			},
		},
		linkback = "block_00211",
		linknext = "block_00213",
		line = 637,
	},
	block_00213 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_02", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c003", file="z004600257"},
			},
			ja = {
				{
					"「如黛莉拉那样的例子，或许曾经是存在过。可你且看看现状，看看这文明无力复兴，逐渐为绿海所吞没的现状！」",
				},
			},
		},
		linkback = "block_00212",
		linknext = "block_00214",
		line = 639,
	},
	block_00214 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004600258"},
			},
			ja = {
				{
					"「……就当ＡＩ能在地球上甩出那么些台拥有完全自我的仿生人，可我不觉得光靠它们就能实现人类复兴」",
				},
			},
		},
		linkback = "block_00213",
		linknext = "block_00215",
		line = 640,
	},
	block_00215 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_08", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600259"},
			},
			ja = {
				{
					"「同感。仅凭些许援助，是无法对现状产生决定性影响的。",
				},
			},
		},
		linkback = "block_00214",
		linknext = "block_00216",
		line = 642,
	},
	block_00216 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_01", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z004600260"},
			},
			ja = {
				{
					"这并非真正有效地使用Ａｅ型的方法。我便是为此找到你、提出委托的。",
				},
			},
		},
		linkback = "block_00215",
		linknext = "block_00217",
		line = 644,
	},
	block_00217 = {
		{"fg", file="bs2_wi01_base01", face="bs2_wi_f01_02", ch="c005", path=":fg/", time=300, mode=3, head="bs2_wi0", lv=3, id=13},
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c003", file="z004600261"},
			},
			ja = {
				{
					"而如今，她来到了我面前」",
				},
			},
		},
		linkback = "block_00216",
		linknext = "block_00218",
		line = 646,
	},
	block_00218 = {
