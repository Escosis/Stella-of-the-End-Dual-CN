		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c002", file="z002800160"},
			},
			ja = {
				{
					"「是的。我读了那里的日志，有一个人提问“可以为了自己的孩子去死吗？”有很多人都回答了这个问题」",
				},
			},
