	block_00139 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004300175"},
			},
			ja = {
				{
					"「对。我当时还只是个小屁孩，却没人愿意可怜可怜我。家里的房子是借来的，人家毫不留情地把我踹了出去。",
