				{"vo", ch="c001", file="z004300222"},
			},
			ja = {
				{
					"当我放弃这些，做回一个人的那一瞬间，我就会变回那个人渣。所以工作对我来说，分量是很重的。",
				},
			},
		},
		linkback = "block_00183",
