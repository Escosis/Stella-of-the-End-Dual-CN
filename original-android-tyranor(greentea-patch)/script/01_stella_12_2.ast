		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004300221"},
			},
			ja = {
				{
					"「我只有工作了。至少在工作里，只要能干出成果就会受人感谢，我看上的就只有这一点。我是为了自我肯定才投入到工作里的。",
