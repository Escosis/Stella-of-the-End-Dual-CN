			ja = {
				{
					"按村里的规矩，进遗迹是犯忌的，可我管他那么多。我在遗迹里几次险死还生，终究是活了下来」",
				},
			},
		},
		linkback = "block_00142",
		linknext = "block_00144",
		line = 448,
	},
