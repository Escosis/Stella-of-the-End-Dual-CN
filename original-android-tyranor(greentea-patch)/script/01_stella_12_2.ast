		text = {
			vo = {
				{"vo", ch="c001", file="z004300178"},
			},
			ja = {
				{
					"我去求那老头学了些本事，之后又把所有家底都给了他，拿下了他的装备。其实也就是把老古董似的枪罢了。我带着那把枪……进了遗迹。",
				},
			},
		},
		linkback = "block_00141",
		linknext = "block_00143",
		line = 447,
