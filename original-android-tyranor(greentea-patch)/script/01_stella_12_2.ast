				{"vo", ch="c001", file="z004300214"},
			},
			ja = {
				{
					"「那墓前除了老婆的，还刻着个不认识的名字。",
				},
			},
		},
		linkback = "block_00175",
		linknext = "block_00177",
		line = 548,
	},
	block_00177 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004300215"},
			},
			ja = {
				{
					"这种事情，在这世道倒也不稀奇。",
				},
			},
		},
		linkback = "block_00176",
		linknext = "block_00178",
		line = 549,
	},
	block_00178 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z004300216"},
			},
			ja = {
				{
					"可我大受打击，比想象中重得多」",
				},
			},
		},
		linkback = "block_00177",
		linknext = "block_00179",
		line = 550,
	},
	block_00179 = {
