			},
			ja = {
				{
					"「然而，到了这个节骨眼，村里却把我放逐了」",
				},
			},
		},
		linkback = "block_00156",
		linknext = "block_00158",
		line = 492,
	},
	block_00158 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c002", file="z004300196"},
			},
			ja = {
				{
					"「放逐？」",
				},
			},
		},
		linkback = "block_00157",
		linknext = "block_00159",
		line = 493,
	},
	block_00159 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z004300197"},
			},
			ja = {
				{
					"「呵呵，一半目的就是单纯想找我的茬。我年少轻狂还闯出些名堂，招了他们的嫉恨」",
				},
			},
		},
		linkback = "block_00158",
		linknext = "block_00160",
		line = 494,
	},
	block_00160 = {
		{"colortone", style="reset"},
		{"cgdel", id=-1},
