		line = 500,
	},
	block_00161 = {
		{"msgoff"},
		{"fg", mode=-2, sync=0},
		{"bg", file="b_bg38", sync=0, zoom=125, path=":bg2/", set="bg38"},
		{"bg", id=1, lv=1, file="cinema200", path=":fgf/", sync=0},
		{"fg", file="bs3_jd02_base01", face="bs3_jd_f01_04", ch="c001", path=":fg/", sync=0, mode=3, head="bs3_jd0", lv=3, id=13},
		{"extrans", time=1000},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004300199"},
			},
			ja = {
				{
					"「他们威胁我说，只要我不再做渡物客的营生，回到我该待的位置上去，就撤销放逐的决定。那个女人也劝我照做。",
				},
			},
		},
		linkback = "block_00160",
		linknext = "block_00162",
		line = 506,
	},
	block_00162 = {
		{"fg", file="bs3_jd02_base01", face="bs3_jd_f01_13", ch="c001", path=":fg/", time=300, mode=3, head="bs3_jd0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004300200"},
			},
			ja = {
				{
					"她就这样。",
				},
			},
		},
		linkback = "block_00161",
		linknext = "block_00163",
		line = 508,
	},
	block_00163 = {
		{"fg", file="bs3_jd02_base01", face="bs3_jd_f01_12", ch="c001", path=":fg/", time=300, mode=3, head="bs3_jd0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004300201"},
			},
			ja = {
				{
					"拘泥于那些个大道理和条条框框……有些地方和你有点像。不愿反抗施暴者的压迫，反而觉得受害者应该忍气吞声。",
				},
			},
		},
		linkback = "block_00162",
		linknext = "block_00164",
		line = 510,
	},
	block_00164 = {
		{"fg", file="bs3_jd02_base01", face="bs3_jd_f01_08", ch="c001", path=":fg/", time=300, mode=3, head="bs3_jd0", lv=3, id=13},
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z004300202"},
			},
			ja = {
				{
					"……我没向他们低头。我是不可能认怂的」",
				},
			},
		},
		linkback = "block_00163",
		linknext = "block_00165",
		line = 512,
	},
	block_00165 = {
		{"fg", file="bs3_jd02_base01", face="bs3_jd_f01_04", ch="c001", path=":fg/", time=300, mode=3, head="bs3_jd0", lv=3, id=13},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004300203"},
			},
			ja = {
				{
					"「我扔下老婆女儿，甩手出了村子」",
				},
			},
		},
		linkback = "block_00164",
		linknext = "block_00166",
		line = 514,
	},
	block_00166 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c002", file="z004300204"},
			},
			ja = {
				{
					"「……！」",
				},
			},
		},
		linkback = "block_00165",
		linknext = "block_00167",
		line = 515,
	},
	block_00167 = {
		{"cgdel", id=1, lv=1},
		{"msgoff"},
		{"cgdel", id=-1},
		{"fg", mode=-2},
		{"bg", file="white", time=1000, path=":bg/"},
		{"bg", id=7, lv=9, movie=1, movieloop=1, style="blend", file="ef_rec_white00", ax=0, ay=0, path=":ani/", bx=960},
		{"bg", id=8, lv=9, movie=1, movieloop=1, file="ef_fnoise00", ax=0, ay=0, zoom=200, alpha=60, path=":ani/", bx=960},
		{"bg", file="bg05", x=-480, y=0, speed=40000, ease="none", time=1000, zoom=150, sync=1, path=":bg/", x2=480, y2=0, set="bg05"},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004300205"},
			},
			ja = {
				{
					"「为了在新的地方站稳脚跟，我吃尽了苦头。",
				},
			},
		},
		linkback = "block_00166",
		linknext = "block_00168",
		line = 523,
	},
	block_00168 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004300206"},
			},
			ja = {
				{
					"但一段时间后，我就成了小有名气的新锐渡物客，这得归功于我自暴自弃，净接些危险的活干。",
				},
			},
		},
		linkback = "block_00167",
		linknext = "block_00169",
		line = 524,
	},
	block_00169 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z004300207"},
			},
			ja = {
				{
					"那时候，我酣畅淋漓，觉得自己的坚持得到了认可」",
				},
			},
		},
		linkback = "block_00168",
		linknext = "block_00170",
		line = 525,
	},
	block_00170 = {
		{"msgoff"},
		{"bg", file="bg78_01", x=480, y=0, speed=40000, ease="none", time=1000, zoom=150, sync=1, path=":bg/", x2=-480, y2=0, set="bg78"},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004300208"},
			},
			ja = {
				{
					"「某天，我搞到一台高性能过滤器。",
				},
			},
		},
		linkback = "block_00169",
		linknext = "block_00171",
		line = 530,
	},
	block_00171 = {
		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004300209"},
			},
			ja = {
				{
					"这让我想起村里面临慢性缺水的问题。我倒不是想救他们，只是好奇他们会不会来求我，而最根本的理由是我放不下老婆和孩子。",
				},
			},
		},
		linkback = "block_00170",
		linknext = "block_00172",
		line = 531,
	},
	block_00172 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z004300210"},
			},
			ja = {
				{
					"我有种感觉，再不回去，可能这辈子就再没机会让女儿把我当父亲看了。毕竟当时离我出走已经过了好几年了嘛」",
				},
			},
		},
		linkback = "block_00171",
		linknext = "block_00173",
		line = 532,
	},
	block_00173 = {
		{"bgm", stop=1, time=2000},
		{"msgoff"},
