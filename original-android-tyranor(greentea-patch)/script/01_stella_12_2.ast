			vo = {
				{"vo", ch="c001", file="z004300176"},
			},
			ja = {
				{
					"好在村里那些人看我还能干点农活，总算是没直接把我扔出村去。那时候，过的就是奴隶日子」",
				},
			},
		},
		linkback = "block_00139",
		linknext = "block_00141",
		line = 440,
	},
