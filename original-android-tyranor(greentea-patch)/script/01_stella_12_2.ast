		text = {
			vo = {
				{"vo", ch="c001", file="z004300177"},
			},
			ja = {
				{
					"「有一天，村里来了个渡物客。那老头虽然年纪大了，但能耐是货真价实的。然而村里并不怎么待见他。",
				},
