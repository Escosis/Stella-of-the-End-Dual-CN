		{"text"},
		text = {
			vo = {
				{"vo", ch="c001", file="z004300211"},
			},
			ja = {
				{
					"「村子没了。闹饥荒」",
				},
			},
		},
		linkback = "block_00172",
		linknext = "block_00174",
		line = 538,
	},
	block_00174 = {
		{"bgm", file="bgm14"},
		{"text"},
		text = {
			vo = {
				{"vo", ch="c002", file="z004300212"},
			},
			ja = {
				{
					"「……嘶！」",
				},
			},
		},
		linkback = "block_00173",
		linknext = "block_00175",
		line = 542,
	},
	block_00175 = {
		{"text"},
		text = {
			pagebreak = true,
			vo = {
				{"vo", ch="c001", file="z004300213"},
			},
			ja = {
				{
					"「老婆和女儿也死了」",
				},
			},
		},
		linkback = "block_00174",
		linknext = "block_00176",
		line = 543,
	},
	block_00176 = {
