		{"text"},
		text = {
			vo = {
				{"vo", ch="c003", file="z003000361"},
			},
			ja = {
				{
					"『恐惧是人类进化不可缺少的因素。可以说没有恐惧，人类的精神文明就无法建立。",
				},
			},
		},
		linkback = "block_00300",
		linknext = "block_00302",
		line = 729,
	},
	block_00302 = {
