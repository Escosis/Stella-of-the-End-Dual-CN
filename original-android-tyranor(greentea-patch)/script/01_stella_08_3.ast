	block_00170 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"各种以人类的智力水平难以处理的问题接二连三地出现。",
				},
			},
		},
		linkback = "block_00169",
		linknext = "block_00171",
		line = 455,
	},
	block_00171 = {
		{"text"},
		text = {
			ja = {
				{
					"曾经稳如泰山的国际社会濒临瓦解。",
				},
			},
		},
		linkback = "block_00170",
		linknext = "block_00172",
		line = 456,
	},
	block_00172 = {
		{"text"},
		text = {
			ja = {
				{
					"为了攻克这些难题，一些国家尝试将公益事业委托给ＡＩ来负责。",
				},
			},
		},
		linkback = "block_00171",
		linknext = "block_00173",
		line = 457,
	},
	block_00173 = {
		{"text"},
		text = {
			ja = {
				{
					"最开始，他们的计划似乎还是颇有成效的。",
				},
			},
		},
		linkback = "block_00172",
		linknext = "block_00174",
		line = 458,
	},
	block_00174 = {
		{"text"},
		text = {
			ja = {
				{
					"食品产量不足，ＡＩ便会改良食品制造设施，保证物资的稳定供应。人工卫星出故障，ＡＩ就会生产并发射自动修理卫星。",
				},
			},
		},
		linkback = "block_00173",
		linknext = "block_00175",
		line = 459,
	},
	block_00175 = {
		{"text"},
		text = {
			ja = {
				{
					"当然，这些小事，能干的执政者应该也能做到。",
				},
			},
		},
		linkback = "block_00174",
		linknext = "block_00176",
		line = 460,
	},
	block_00176 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"但ＡＩ的行为逐渐超越了人类所能理解的范畴。",
				},
			},
		},
		linkback = "block_00175",
		linknext = "block_00177",
		line = 461,
	},
	block_00177 = {
		{"text"},
		text = {
			ja = {
				{
					"处理问题的程序在复杂化的道路上越走越远。",
				},
			},
		},
		linkback = "block_00176",
		linknext = "block_00178",
		line = 462,
	},
	block_00178 = {
		{"text"},
		text = {
			ja = {
				{
					"人们很难直观地理解ＡＩ想要做什么，以及它们的行为又是如何产生作用的。",
				},
			},
		},
		linkback = "block_00177",
		linknext = "block_00179",
		line = 463,
	},
	block_00179 = {
		{"text"},
		text = {
			ja = {
				{
					"后来，为了帮助人类理解ＡＩ的意图，翻译就成了必不可少的一环。",
				},
			},
		},
		linkback = "block_00178",
		linknext = "block_00180",
		line = 464,
	},
	block_00180 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"然而这些ＡＩ翻译在历史的舞台上不过是匆匆过客。",
				},
			},
		},
		linkback = "block_00179",
		linknext = "block_00181",
		line = 465,
	},
	block_00181 = {
		{"text"},
		text = {
			ja = {
				{
					"ＡＩ的眼光过于长远，仅过了几十年，就已经再没有人能看懂它们所行之事的全貌。",
				},
			},
		},
		linkback = "block_00180",
		linknext = "block_00182",
		line = 466,
	},
	block_00182 = {
		{"text"},
		text = {
			ja = {
				{
					"不借助任何辅助，人类是不可能解读出蝴蝶扇动翅膀和远处的天气变化间有什么样的因果联系的。",
				},
			},
		},
		linkback = "block_00181",
		linknext = "block_00183",
		line = 467,
	},
	block_00183 = {
		{"text"},
		text = {
			ja = {
				{
					"ＡＩ没有为人类做出任何说明。",
				},
			},
		},
		linkback = "block_00182",
		linknext = "block_00184",
		line = 468,
	},
	block_00184 = {
		{"text"},
		text = {
			ja = {
				{
					"就好像写了源代码却不加注释。",
				},
			},
		},
		linkback = "block_00183",
		linknext = "block_00185",
		line = 469,
	},
	block_00185 = {
		{"text"},
		text = {
			ja = {
				{
					"但就算加了注释，人们也理解不了。",
				},
			},
		},
		linkback = "block_00184",
		linknext = "block_00186",
		line = 470,
	},
	block_00186 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"人类无法理解，对ＡＩ来说，当前的最优先事项是什么。",
				},
			},
		},
		linkback = "block_00185",
		linknext = "block_00187",
		line = 471,
	},
	block_00187 = {
		{"text"},
		text = {
			ja = {
				{
					"当时就已经有人感到恐惧。",
				},
			},
		},
		linkback = "block_00186",
		linknext = "block_00188",
		line = 472,
	},
	block_00188 = {
		{"text"},
		text = {
			ja = {
				{
					"但那时，一切都还算是在运转顺利。",
				},
			},
		},
		linkback = "block_00187",
		linknext = "block_00189",
		line = 473,
	},
	block_00189 = {
		{"text"},
		text = {
			ja = {
				{
					"既然运转顺利那不就行了吗。",
				},
			},
		},
		linkback = "block_00188",
		linknext = "block_00190",
		line = 474,
	},
	block_00190 = {
		{"text"},
		text = {
			ja = {
				{
					"人类曾经不也是用同样的方式来对待原子能的吗。",
				},
			},
		},
		linkback = "block_00189",
		linknext = "block_00191",
		line = 475,
	},
	block_00191 = {
		{"text"},
		text = {
			pagebreak = true,
			ja = {
				{
					"确实发生过一些悲剧，但最终不也没有演变成人类的灭顶之灾吗。",
				},
			},
		},
		linkback = "block_00190",
		linknext = "block_00192",
		line = 476,
	},
	block_00192 = {
		{"text"},
		text = {
			ja = {
				{
					"人们放弃了思考。",
				},
			},
		},
		linkback = "block_00191",
		linknext = "block_00193",
		line = 477,
	},
	block_00193 = {
		{"text"},
		text = {
			ja = {
				{
					"反而给ＡＩ追加了更多的权限。",
				},
			},
		},
		linkback = "block_00192",
		linknext = "block_00194",
		line = 478,
	},
	block_00194 = {
		{"text"},
		text = {
			ja = {
				{
					"他们选择将自己封闭在名为完备环境都市的茧房中。",
