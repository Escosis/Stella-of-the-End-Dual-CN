		text = {
			vo = {
				{"vo", ch="c003", file="z003000359"},
			},
			ja = {
				{
					"『对了……我曾读到过……在人类最鼎盛时的ＡＩ研究中，为了让机器获得心灵，近似于本能和恐惧的东西也是必要的』",
				},
			},
		},
		linkback = "block_00298",
		linknext = "block_00300",
		line = 726,
	},
	block_00300 = {
