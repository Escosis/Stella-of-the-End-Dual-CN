		},
		linkback = "block_00007",
		linknext = "block_00009",
		line = 29,
	},
	block_00009 = {
		{"text"},
		text = {
			ja = {
				{
					"しかし計画は失敗し、多大な犠牲者を出した。",
				},
			},
		},
		linkback = "block_00008",
		linknext = "block_00010",
		line = 30,
	},
	block_00010 = {
		{"text"},
		text = {
			ja = {
				{
					"中でも最大の規模を誇ったのがあの連中で、当初は１００名を越えていたとか。",
